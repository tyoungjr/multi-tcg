# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# PriceCharting
PRICECHARTING_API_KEY=your-pricecharting-api-key-here
PRICECHARTING_SELLER_ID=your-seller-id-here

# Anthropic (Claude Vision for item identification)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# eBay (optional - for sold listings fallback pricing)
# Register at developer.ebay.com - pending approval is fine, pipeline works without it
EBAY_APP_ID=
EBAY_CERT_ID=

# SerpAPI (optional - for reliable Google Lens results, free tier = 100/month)
# Without this, Google Lens falls back to direct scraping (less reliable)
# Sign up at serpapi.com
SERPAPI_KEY=

# Shopify (for product sync)
# From your Shopify app settings page
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your-client-id
SHOPIFY_CLIENT_SECRET=your-client-secret
# Access token is generated automatically by: npm run shopify:auth
SHOPIFY_ACCESS_TOKEN=

# Snap & Sell server
SNAP_SERVER_PORT=3457
